# Immich version
IMMICH_VERSION=release

# Upload location (must be mounted and writable)
UPLOAD_LOCATION=/mnt/exthdd/immich-storage

# Database location (can be local or on HDD)
DB_DATA_LOCATION=./postgres

# Database credentials (CHANGE THESE)
DB_PASSWORD=CHANGE_ME_TO_RANDOM_PASSWORD
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# Timezone
TZ=Europe/London

# Hardware acceleration
# For Nvidia GPUs - enable hardware transcoding
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,video,utility

# Machine learning workers (adjust based on CPU cores, 12 cores = 8-10 workers)
MACHINE_LEARNING_WORKERS=8
